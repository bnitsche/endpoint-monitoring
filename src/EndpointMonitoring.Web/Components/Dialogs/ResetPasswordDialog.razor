@using EndpointMonitoring.Web.Auth
@inject UserAuthService UserAuth
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Reset Password</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">Set a new password for <b>@Username</b>.</MudText>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_password" Label="New Password" Required="true"
                          InputType="InputType.Password"
                          Validation="@(new Func<string, string?>(ValidatePassword))"
                          RequiredError="Password is required." />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Reset</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public int UserId { get; set; }
    [Parameter] public string Username { get; set; } = "";

    private MudForm _form = null!;
    private bool _isValid;
    private string _password = "";

    private static string? ValidatePassword(string? value) =>
        !string.IsNullOrEmpty(value) && value.Length >= 8 ? null : "Password must be at least 8 characters.";

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        try
        {
            await UserAuth.ResetPasswordAsync(UserId, _password);
        }
        catch (AuthOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            return;
        }

        Snackbar.Add("Password reset.", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
