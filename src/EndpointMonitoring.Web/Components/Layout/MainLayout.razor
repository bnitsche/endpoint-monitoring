@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-3">Endpoint Monitoring</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex">@context.User.Identity?.Name</MudText>
                <form method="post" action="/Account/Logout" style="display:inline;">
                    <AntiforgeryToken />
                    <MudButton ButtonType="ButtonType.Submit" Color="Color.Inherit" Class="d-none d-sm-inline-flex"
                               StartIcon="@Icons.Material.Filled.Logout">Logout</MudButton>
                    <MudIconButton ButtonType="ButtonType.Submit" Color="Color.Inherit" Class="d-sm-none"
                                   Icon="@Icons.Material.Filled.Logout" title="Logout" />
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6" Color="Color.Primary">Navigation</MudText>
        </MudDrawerHeader>
        <NavMenu />
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="px-4 pb-2 mud-text-secondary" title="@AppInfo.Version">
            v@(_displayVersion)
        </MudText>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    // "2026.1.0606.1432+ab12cd3" → "2026.1.0606.1432 (ab12cd3)"; full string in the tooltip.
    private static readonly string _displayVersion = AppInfo.Version.Replace("+", " (")
        + (AppInfo.Version.Contains('+') ? ")" : "");
}
