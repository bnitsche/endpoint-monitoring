@page "/logs"
@attribute [Authorize(Policy = "AdminOnly")]
@using System.Globalization
@using System.Text
@using EndpointMonitoring.Core.Logging
@using EndpointMonitoring.Web.Services
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@inject LogStreamService LogStream
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Logs – Endpoint Monitoring</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Logs</MudText>

<MudGrid Class="mb-4" Spacing="2">
    <MudItem xs="6" sm="3">
        <MudSelect T="string" @bind-Value="_sourceFilter" Label="Source" AnchorOrigin="Origin.BottomLeft"
                   Clearable="true" ClearIcon="@Icons.Material.Filled.Clear">
            <MudSelectItem T="string" Value="@LogEntry.WebServiceName">@LogEntry.WebServiceName</MudSelectItem>
            <MudSelectItem T="string" Value="@LogEntry.MonitoringServiceName">@LogEntry.MonitoringServiceName</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudSelect T="LogLevel" @bind-Value="_minLevel" Label="Min. Level" AnchorOrigin="Origin.BottomLeft">
            <MudSelectItem T="LogLevel" Value="LogLevel.Trace">Trace</MudSelectItem>
            <MudSelectItem T="LogLevel" Value="LogLevel.Debug">Debug</MudSelectItem>
            <MudSelectItem T="LogLevel" Value="LogLevel.Information">Information</MudSelectItem>
            <MudSelectItem T="LogLevel" Value="LogLevel.Warning">Warning</MudSelectItem>
            <MudSelectItem T="LogLevel" Value="LogLevel.Error">Error</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudTextField T="string" @bind-Value="_search" Label="Search" Immediate="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" />
    </MudItem>
</MudGrid>

<MudPaper Elevation="2">
    <MudToolBar Class="px-4">
        <MudText Typo="Typo.h6">Live Log</MudText>
        <MudSpacer />
        @if (_lastSignalAt.HasValue)
        {
            <MudTooltip Text="Last log entry received">
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Sensors"
                         Color="@(_paused ? Color.Default : Color.Success)" Variant="Variant.Outlined"
                         Class="mr-2 d-none d-sm-inline-flex">
                    @_lastSignalAt.Value.ToString("G", _culture)
                </MudChip>
            </MudTooltip>
        }
        <MudTooltip Text="@(_paused ? "Resume live updates" : "Pause live updates")">
            <MudIconButton Icon="@(_paused ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Pause)"
                           Color="@(_paused ? Color.Warning : Color.Default)" OnClick="TogglePause" />
        </MudTooltip>
        <MudTooltip Text="@(_plainTextView ? "Show as table" : "Show as plain text")">
            <MudIconButton Icon="@(_plainTextView ? Icons.Material.Filled.TableRows : Icons.Material.Filled.Subject)"
                           Color="@(_plainTextView ? Color.Primary : Color.Default)" OnClick="TogglePlainText" />
        </MudTooltip>
        <MudTooltip Text="Export as text file">
            <MudIconButton Icon="@Icons.Material.Filled.Download" OnClick="ExportAsync" />
        </MudTooltip>
        <MudTooltip Text="Clear view">
            <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" OnClick="ClearView" />
        </MudTooltip>
    </MudToolBar>

@if (_plainTextView)
{
    <pre class="log-plain">@BuildPlainText(FilteredEntries)</pre>
}
else
{
<MudTable Items="FilteredEntries" Hover="true" Dense="true" Elevation="0"
          FixedHeader="true" Height="62vh" Virtualize="true">
    <HeaderContent>
        <MudTh Style="width: 170px;">Time</MudTh>
        <MudTh Style="width: 110px;">Level</MudTh>
        <MudTh Style="width: 140px;">Source</MudTh>
        <MudTh Style="width: 200px;">Category</MudTh>
        <MudTh>Message</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Time" Style="white-space: nowrap;">@context.Timestamp.ToLocalTime().ToString("G", _culture)</MudTd>
        <MudTd DataLabel="Level">
            <MudChip T="string" Size="Size.Small" Color="@LevelColor(context.Level)" Variant="Variant.Filled">
                @LevelLabel(context.Level)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Source" HideSmall="true">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ServiceName</MudChip>
        </MudTd>
        <MudTd DataLabel="Category" HideSmall="true">
            <MudTooltip Text="@context.Category">
                <span>@ShortCategory(context.Category)</span>
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Message" Style="word-break: break-word;">
            @context.Message
            @if (!string.IsNullOrEmpty(context.Exception))
            {
                <pre class="log-exception">@context.Exception</pre>
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-4">No log entries match the current filter.</MudText>
    </NoRecordsContent>
</MudTable>
}
</MudPaper>

<style>
    pre.log-plain {
        margin: 0;
        padding: 12px 16px;
        height: 62vh;
        overflow: auto;
        font-size: 0.8rem;
        line-height: 1.45;
        white-space: pre-wrap;
        word-break: break-word;
    }

    pre.log-exception {
        margin: 4px 0 0;
        padding: 4px 8px;
        max-height: 160px;
        overflow: auto;
        font-size: 0.75rem;
        background-color: rgba(244, 67, 54, 0.08);
        border-left: 3px solid rgba(244, 67, 54, 0.6);
        white-space: pre-wrap;
        word-break: break-word;
    }
</style>

@code {
    private List<LogEntry> _entries = [];   // newest first
    private string? _sourceFilter;
    private LogLevel _minLevel = LogLevel.Information;
    private string? _search;
    private bool _paused;
    private bool _plainTextView;
    private CultureInfo _culture = CultureInfo.CurrentCulture;
    private DateTime? _lastSignalAt;

    private IEnumerable<LogEntry> FilteredEntries => _entries.Where(e =>
        e.Level >= _minLevel
        && (_sourceFilter is null || e.ServiceName == _sourceFilter)
        && (string.IsNullOrWhiteSpace(_search)
            || e.Message.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || e.Category.Contains(_search, StringComparison.OrdinalIgnoreCase)));

    protected override void OnInitialized()
    {
        _culture = CultureInfo.CurrentCulture;
        LogStream.OnLogReceived += OnLogReceived;
        Resync();
    }

    public void Dispose() => LogStream.OnLogReceived -= OnLogReceived;

    private void OnLogReceived(LogEntry entry)
    {
        if (_paused)
            return;

        _ = InvokeAsync(() =>
        {
            _lastSignalAt = DateTime.Now;
            _entries.Insert(0, entry);
            if (_entries.Count > LogStreamService.Capacity)
                _entries.RemoveAt(_entries.Count - 1);
            StateHasChanged();
        });
    }

    // Reloads the view from the buffer, e.g. after resuming from pause.
    private void Resync() => _entries = [.. LogStream.GetSnapshot().Reverse()];

    private void TogglePause()
    {
        _paused = !_paused;
        if (!_paused)
            Resync();   // catch up on entries that arrived while paused
    }

    private void ClearView() => _entries = [];

    private void TogglePlainText() => _plainTextView = !_plainTextView;

    /// <summary>Formats entries as plain text, one line per entry, exceptions indented below.</summary>
    private string BuildPlainText(IEnumerable<LogEntry> entries)
    {
        var sb = new StringBuilder();
        foreach (var e in entries)
        {
            sb.Append(e.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff", CultureInfo.InvariantCulture))
              .Append(" [").Append(LevelLabel(e.Level)).Append(']')
              .Append(" [").Append(e.ServiceName).Append("] ")
              .Append(e.Category).Append(": ")
              .AppendLine(e.Message);

            if (!string.IsNullOrEmpty(e.Exception))
            {
                foreach (var line in e.Exception.Split('\n'))
                    sb.Append("    ").AppendLine(line.TrimEnd('\r'));
            }
        }
        return sb.ToString();
    }

    /// <summary>Downloads the currently filtered entries (oldest first) as a UTF-8 text file.</summary>
    private async Task ExportAsync()
    {
        var text = BuildPlainText(FilteredEntries.Reverse());
        var fileName = $"endpoint-monitoring-logs-{DateTime.Now:yyyyMMdd-HHmmss}.txt";

        using var stream = new MemoryStream(Encoding.UTF8.GetBytes(text));
        using var streamRef = new DotNetStreamReference(stream);

        await using var module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./Components/Pages/Logs.razor.js");
        await module.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    private static Color LevelColor(LogLevel level) => level switch
    {
        LogLevel.Warning => Color.Warning,
        LogLevel.Error or LogLevel.Critical => Color.Error,
        LogLevel.Information => Color.Info,
        _ => Color.Default
    };

    private static string LevelLabel(LogLevel level) => level switch
    {
        LogLevel.Trace => "TRC",
        LogLevel.Debug => "DBG",
        LogLevel.Information => "INF",
        LogLevel.Warning => "WRN",
        LogLevel.Error => "ERR",
        LogLevel.Critical => "CRT",
        _ => level.ToString()
    };

    private static string ShortCategory(string category)
    {
        var idx = category.LastIndexOf('.');
        return idx >= 0 && idx < category.Length - 1 ? category[(idx + 1)..] : category;
    }
}
