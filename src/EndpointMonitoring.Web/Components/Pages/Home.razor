@page "/"
@using EndpointMonitoring.Core.Data
@using EndpointMonitoring.Core.Models
@using EndpointMonitoring.Web.Services
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IMonitoringUpdateNotifier UpdateNotifier
@implements IDisposable

<PageTitle>Dashboard – Endpoint Monitoring</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.overline" Color="Color.Default">Total Endpoints</MudText>
                <MudText Typo="Typo.h4">@_total</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.overline" Color="Color.Success">Healthy</MudText>
                <MudText Typo="Typo.h4" Color="Color.Success">@_healthy</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.overline" Color="Color.Error">Failing</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@_failing</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.overline" Color="Color.Warning">No Data</MudText>
                <MudText Typo="Typo.h4" Color="Color.Warning">@_noData</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTable Items="_statusRows" Hover="true" Dense="true" Elevation="2" RowClassFunc="GetRowClass">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Endpoint Status</MudText>
            <MudSpacer />
            @if (_lastSignalAt.HasValue)
            {
                <MudTooltip Text="Last real-time update received from monitoring service">
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Sensors"
                             Color="Color.Success" Variant="Variant.Outlined" Class="mr-2">
                        @_lastSignalAt.Value.ToString("G", _culture)
                    </MudChip>
                </MudTooltip>
            }
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Provider</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Last Check</MudTh>
            <MudTh>Last Error</MudTh>
            <MudTh>Response (ms)</MudTh>
            <MudTh>Message</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.ProviderType</MudChip>
            </MudTd>
            <MudTd>
                @if (!context.HasResult)
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">No data</MudChip>
                }
                else if (context.IsSuccess == true && !context.HasUnacknowledgedAlert)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">OK</MudChip>
                }
                else if (context.IsSuccess == true && context.HasUnacknowledgedAlert)
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.WarningAmber">Recovered</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Error">FAIL</MudChip>
                }
            </MudTd>
            <MudTd>@FmtDate(context.CheckedAt)</MudTd>
            <MudTd>@FmtDate(context.LastFailureAt)</MudTd>
            <MudTd>@(context.ResponseTimeMs?.ToString() ?? "–")</MudTd>
            <MudTd>@(context.StatusMessage ?? "–")</MudTd>
            <MudTd>
                @if (context.HasUnacknowledgedAlert)
                {
                    <AuthorizeView Roles="@AppRoles.Admin" Context="authCtx">
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.NotificationsOff"
                                   OnClick="() => AcknowledgeAsync(context.EndpointId)">
                            Acknowledge
                        </MudButton>
                    </AuthorizeView>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<style>
    @@keyframes rowFlash {
        0%   { background-color: rgba(255, 193, 7, 0.45); }
        35%  { background-color: rgba(255, 193, 7, 0.05); }
        60%  { background-color: rgba(255, 193, 7, 0.45); }
        100% { background-color: transparent; }
    }

    tr.row-flash > td {
        animation: rowFlash 1s ease-out forwards;
    }
</style>

@code {
    private bool _loading = true;
    private int _total, _healthy, _failing, _noData;
    private List<StatusRow> _statusRows = [];
    private CultureInfo _culture = CultureInfo.CurrentCulture;
    private HashSet<int> _highlightedRows = [];
    private DateTime? _lastSignalAt;

    private string FmtDate(DateTime? dt) => dt?.ToLocalTime().ToString("G", _culture) ?? "–";

    private string GetRowClass(StatusRow row, int _) =>
        _highlightedRows.Contains(row.EndpointId) ? "row-flash" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _culture = CultureInfo.CurrentCulture;
        UpdateNotifier.OnEndpointChecked += OnEndpointChecked;
        await LoadAsync();
    }

    public void Dispose() => UpdateNotifier.OnEndpointChecked -= OnEndpointChecked;

    private void OnEndpointChecked(int endpointId) =>
        _ = InvokeAsync(async () =>
        {
            _lastSignalAt = DateTime.Now;
            await RefreshRowAsync(endpointId);
            _highlightedRows.Add(endpointId);
            StateHasChanged();

            await Task.Delay(1000);

            _highlightedRows.Remove(endpointId);
            StateHasChanged();
        });

    private async Task RefreshRowAsync(int endpointId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var endpoint = await db.Endpoints
            .Where(e => e.Id == endpointId && e.IsEnabled)
            .FirstOrDefaultAsync();

        if (endpoint is null)
        {
            _statusRows.RemoveAll(r => r.EndpointId == endpointId);
        }
        else
        {
            var result = await db.Results
                .Where(r => r.EndpointId == endpointId)
                .OrderByDescending(r => r.CheckedAt)
                .FirstOrDefaultAsync();

            var lastFailureAt = await db.Results
                .Where(r => r.EndpointId == endpointId && !r.IsSuccess)
                .MaxAsync(r => (DateTime?)r.CheckedAt);

            var updated = new StatusRow(endpoint.Id, endpoint.Name, endpoint.ProviderType,
                                        result?.IsSuccess, result?.CheckedAt,
                                        result?.ResponseTimeMs, result?.StatusMessage,
                                        endpoint.AlertSentAt, lastFailureAt);

            var idx = _statusRows.FindIndex(r => r.EndpointId == endpointId);
            if (idx >= 0)
                _statusRows[idx] = updated;
            else
                _statusRows.Add(updated);
        }

        _total = _statusRows.Count;
        _healthy = _statusRows.Count(r => r.IsSuccess == true && !r.HasUnacknowledgedAlert);
        _failing = _statusRows.Count(r => r.IsSuccess == false);
        _noData = _statusRows.Count(r => r.IsSuccess == null);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();

        var endpoints = await db.Endpoints
            .Where(e => e.IsEnabled)
            .OrderBy(e => e.Name)
            .ToListAsync();

        var endpointIds = endpoints.Select(e => e.Id).ToList();

        var latestResults = await db.Results
            .Where(r => endpointIds.Contains(r.EndpointId))
            .GroupBy(r => r.EndpointId)
            .Select(g => g.OrderByDescending(r => r.CheckedAt).First())
            .ToListAsync();

        var lastFailureTimes = await db.Results
            .Where(r => endpointIds.Contains(r.EndpointId) && !r.IsSuccess)
            .GroupBy(r => r.EndpointId)
            .Select(g => new { EndpointId = g.Key, At = g.Max(r => r.CheckedAt) })
            .ToListAsync();

        _statusRows = endpoints.Select(e =>
        {
            var result = latestResults.FirstOrDefault(r => r.EndpointId == e.Id);
            var lastFailureAt = lastFailureTimes.FirstOrDefault(x => x.EndpointId == e.Id)?.At;
            return new StatusRow(e.Id, e.Name, e.ProviderType, result?.IsSuccess, result?.CheckedAt,
                                 result?.ResponseTimeMs, result?.StatusMessage, e.AlertSentAt, lastFailureAt);
        }).ToList();

        _total = _statusRows.Count;
        _healthy = _statusRows.Count(r => r.IsSuccess == true && !r.HasUnacknowledgedAlert);
        _failing = _statusRows.Count(r => r.IsSuccess == false);
        _noData = _statusRows.Count(r => r.IsSuccess == null);

        _loading = false;
    }

    private async Task AcknowledgeAsync(int endpointId)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var endpoint = await db.Endpoints.FindAsync(endpointId);
        if (endpoint is null) return;
        endpoint.AlertSentAt = null;
        await db.SaveChangesAsync();
        Snackbar.Add("Alert acknowledged. A new notification will be sent on the next failure.", Severity.Info);
        await LoadAsync();
    }

    private record StatusRow(int EndpointId, string Name, string ProviderType, bool? IsSuccess,
                              DateTime? CheckedAt, int? ResponseTimeMs, string? StatusMessage,
                              DateTime? AlertSentAt, DateTime? LastFailureAt)
    {
        public bool HasResult => IsSuccess.HasValue;
        public bool HasUnacknowledgedAlert => AlertSentAt.HasValue;
    }
}
