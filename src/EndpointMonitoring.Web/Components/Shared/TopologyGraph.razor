@using EndpointMonitoring.Web.Services.Topology

<div class="topo-scroll">
    <svg class="topo-svg"
         viewBox="0 0 @TopologyLayout.Fmt(Model.Width) @TopologyLayout.Fmt(Model.Height)"
         preserveAspectRatio="xMinYMin meet"
         style="min-width: @(TopologyLayout.Fmt(Model.Width))px; height: @(TopologyLayout.Fmt(Model.Height))px;"
         role="img" aria-label="System topology">

        <defs>
            @* Rounds the accent stripe's left corners to the card silhouette. The stripe only occupies
               the left few pixels, where the rounded shape is identical for every card width, so one
               oversized clip rect serves cards of any width. *@
            <clipPath id="topo-node-clip">
                <rect width="2000" height="@TopologyLayout.Fmt(TopologyLayout.NodeH)" rx="10" />
            </clipPath>
            @* Theme-agnostic top-light / bottom-shade to give the flat cards depth. *@
            <linearGradient id="topo-node-sheen" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#ffffff" stop-opacity="0.08" />
                <stop offset="55%" stop-color="#ffffff" stop-opacity="0" />
                <stop offset="100%" stop-color="#000000" stop-opacity="0.14" />
            </linearGradient>
        </defs>

        @* Edges first so nodes paint on top; failing links drawn last so they stay visible. *@
        @foreach (var edge in Model.Edges.OrderBy(e => e.State == EdgeState.Down ? 1 : 0))
        {
            var from = Model.Node(edge.FromId);
            var to = Model.Node(edge.ToId);
            if (from is null || to is null)
                continue;

            var d = TopologyLayout.EdgePath(from, to);

            <path d="@d" pathLength="100" class="topo-edge @EdgeClass(edge)" />

            @if (edge.Pulsing)
            {
                <path d="@d" pathLength="100" class="topo-edge-pulse" />
            }
        }

        @foreach (var node in Model.Nodes)
        {
            <g class="topo-node @StatusClass(node.Status)"
               transform="translate(@TopologyLayout.Fmt(node.X), @TopologyLayout.Fmt(node.Y))">
                <title>@(node.Tooltip ?? node.Label)</title>
                <rect class="topo-rect" width="@TopologyLayout.Fmt(node.Width)" height="@TopologyLayout.Fmt(TopologyLayout.NodeH)" rx="10" />
                <rect class="topo-sheen" width="@TopologyLayout.Fmt(node.Width)" height="@TopologyLayout.Fmt(TopologyLayout.NodeH)" rx="10" />
                <rect class="topo-accent" width="6" height="@TopologyLayout.Fmt(TopologyLayout.NodeH)" clip-path="url(#topo-node-clip)" />
                <circle class="topo-pulse" cx="20" cy="18" r="5" />
                <circle class="topo-status-dot" cx="20" cy="18" r="4" />
                @if (node.IconSvg is not null)
                {
                    <g class="topo-icon" transform="translate(32, 18) scale(0.9)">@((MarkupString)node.IconSvg)</g>
                }
                @SvgText("topo-label", TopologyLayout.TextStartX, 24, node.Label)
                @if (node.SubLabel is not null)
                {
                    @SvgText("topo-sublabel", TopologyLayout.TextStartX, 42, Truncate(node.SubLabel, TopologyLayout.SubLabelMax))
                }
                @if (node.Chip is not null)
                {
                    @SvgText("topo-chip", node.Width - 12, 18, node.Chip, anchor: "end")
                }
                @if (node.Badge)
                {
                    <circle class="topo-badge" cx="@TopologyLayout.Fmt(node.Width - 12)" cy="@TopologyLayout.Fmt(TopologyLayout.NodeH - 12)" r="6">
                        <title>Unacknowledged alert</title>
                    </circle>
                }
            </g>
        }

        @* Edge labels last so their opaque pills always sit in the foreground, never hidden by a card. *@
        @foreach (var edge in Model.Edges)
        {
            if (edge.Label is null)
                continue;

            var from = Model.Node(edge.FromId);
            var to = Model.Node(edge.ToId);
            if (from is null || to is null)
                continue;

            var (mx, my) = TopologyLayout.EdgeMid(from, to);
            @SvgEdgeLabel(mx, my, edge.Label)
        }
    </svg>
</div>

@code {
    /// <summary>The topology to render. Layout (X/Y, Width/Height) must already be applied.</summary>
    [Parameter, EditorRequired]
    public required TopologyModel Model { get; set; }

    private static string EdgeClass(TopoEdge edge) => edge.State switch
    {
        EdgeState.Up => "up",
        EdgeState.Down => "down",
        _ => string.Empty
    };

    private static string StatusClass(NodeStatus status) => status switch
    {
        NodeStatus.Success => "success",
        NodeStatus.Warning => "warning",
        NodeStatus.Error => "error",
        _ => "neutral"
    };

    private static string Truncate(string value, int max) =>
        value.Length <= max ? value : value[..(max - 1)] + "…";

    /// <summary>
    /// Renders an SVG &lt;text&gt; element as raw markup, because Razor reserves the
    /// <c>&lt;text&gt;</c> tag for literal text and rejects attributes on it (RZ1023).
    /// </summary>
    private static MarkupString SvgText(string cssClass, double x, double y, string content, string? anchor = null)
    {
        var anchorAttr = anchor is null ? string.Empty : $" text-anchor=\"{anchor}\"";
        var markup = $"<text class=\"{cssClass}\" x=\"{TopologyLayout.Fmt(x)}\" y=\"{TopologyLayout.Fmt(y)}\"{anchorAttr}>"
                     + System.Net.WebUtility.HtmlEncode(content) + "</text>";
        return (MarkupString)markup;
    }

    /// <summary>
    /// Renders an edge label as a centered "pill" (opaque rounded rect + text) so the connector
    /// line behind it is masked and the text stays legible wherever the edge runs. Width is
    /// estimated from the character count since text cannot be measured server-side.
    /// </summary>
    private static MarkupString SvgEdgeLabel(double x, double y, string content)
    {
        var width = content.Length * 6.3 + 16;
        var rectX = x - width / 2;
        var rectY = y - 9;
        var text = System.Net.WebUtility.HtmlEncode(content);

        var markup =
            "<g class=\"topo-edge-label-grp\">"
            + $"<rect class=\"topo-edge-label-bg\" x=\"{TopologyLayout.Fmt(rectX)}\" y=\"{TopologyLayout.Fmt(rectY)}\" "
            + $"width=\"{TopologyLayout.Fmt(width)}\" height=\"18\" rx=\"9\" />"
            + $"<text class=\"topo-edge-label\" x=\"{TopologyLayout.Fmt(x)}\" y=\"{TopologyLayout.Fmt(y + 4)}\">{text}</text>"
            + "</g>";
        return (MarkupString)markup;
    }
}
