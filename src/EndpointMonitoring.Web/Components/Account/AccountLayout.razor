@inherits LayoutComponentBase

<MudThemeProvider />

<div class="account-bg">
    <MudPaper Elevation="0" Class="account-card">
        <div class="account-brand">
            <div class="account-logo">
                <MudIcon Icon="@Icons.Material.Filled.MonitorHeart" Size="Size.Large" />
            </div>
            <MudText Typo="Typo.subtitle1" Class="account-brand-text">Endpoint Monitoring</MudText>
        </div>
        @Body
    </MudPaper>
</div>

<style>
    .account-bg { min-height: 100vh; display: flex; align-items: center; justify-content: center;
        padding: 1.5rem;
        font-family: var(--mud-typography-default-family, 'Roboto', 'Helvetica', 'Arial', sans-serif);
        background:
            radial-gradient(1200px 600px at 15% -10%, rgba(var(--mud-palette-primary-rgb), .18), transparent 60%),
            radial-gradient(900px 500px at 100% 110%, rgba(var(--mud-palette-secondary-rgb), .14), transparent 55%),
            var(--mud-palette-background-grey); }
    .account-card { width: 100%; max-width: 440px; padding: 2.5rem 2.5rem 2.75rem;
        border-radius: 16px; background: var(--mud-palette-surface);
        box-shadow: 0 24px 60px rgba(0, 0, 0, .18), 0 2px 8px rgba(0, 0, 0, .08); }
    .account-brand { display: flex; flex-direction: column; align-items: center; margin-bottom: 1.75rem; }
    .account-logo { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px;
        border-radius: 14px; color: var(--mud-palette-primary-text);
        background: var(--mud-palette-primary);
        box-shadow: 0 6px 16px rgba(var(--mud-palette-primary-rgb), .4); }
    .account-brand-text { margin-top: .75rem; font-weight: 600; letter-spacing: .02em;
        color: var(--mud-palette-text-secondary); text-transform: uppercase; font-size: .8rem; }
</style>
